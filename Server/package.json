{
  "name": "agenda-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test --test-concurrency=1 test/unit/auth.session.test.js test/unit/email.templates.test.js test/unit/validation.schemas.test.js",
    "test:integration": "npm run test:api && npm run test:flow && npm run test:payment && npm run test:websocket",
    "test:api": "node --test test/api.test.js",
    "test:flow": "node --test test/integration.test.js",
    "test:payment": "node --test test/auditPayment.test.js",
    "test:websocket": "node --test test/unit/websocket.auth.test.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "socket.io": "^4.8.3",
    "transbank-sdk": "^6.1.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "socket.io-client": "^4.8.3"
  }
}
