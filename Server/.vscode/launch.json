{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API Tests",
      "runtimeArgs": ["--test"],
      "program": "${workspaceFolder}/test/api.test.js",
      "console": "integratedTerminal"
