---
// Page for admin and worker login
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atmósfera — Iniciar Sesión</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@200;300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --niebla:          #8A9BAE;
      --niebla-claro:    #B8C6D1;
      --niebla-suave:    #DCE4EA;
      --tierra:          #B5A898;
      --fondo:           #F4F2EF;
      --sidebar:         #2C2A27;
      --texto:           #2C2A27;
      --texto-suave:     #7A7570;
      --texto-muted:     #AAA59F;
      --blanco:          #FAF9F7;
      --rojo:            #B5827A;
      --rojo-claro:      #EDD9D6;
      --borde:           #E4E0DC;
    }

    body {
      font-family: 'Jost', sans-serif;
      font-weight: 300;
      color: var(--texto);
      background: var(--fondo);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    .login-container {
      width: 100%;
      max-width: 400px;
      background: var(--blanco);
      border: 1px solid var(--borde);
      box-shadow: 0 15px 45px rgba(44, 42, 39, 0.08);
      border-radius: 6px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .login-header {
      background: var(--sidebar);
      padding: 2.5rem 2rem;
      text-align: center;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .login-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 300;
      font-size: 1.6rem;
      letter-spacing: 0.3em;
      color: var(--niebla-claro);
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }

    .login-header p {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(184,198,209,0.4);
    }

    .login-body {
      padding: 2.2rem 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .form-label {
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--texto-suave);
      font-weight: 500;
    }

    .form-input {
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      padding: 0.75rem 0.9rem;
      background: var(--blanco);
      border: 1px solid var(--borde);
      color: var(--texto);
      border-radius: 3px;
      transition: all 0.2s ease;
      width: 100%;
      outline: none;
    }

    .form-input:focus {
      border-color: var(--niebla);
      box-shadow: 0 0 0 3px var(--niebla-suave);
    }

    .alert-error {
      background: var(--rojo-claro);
      border-left: 3px solid var(--rojo);
      color: var(--rojo);
      font-size: 0.75rem;
      padding: 0.75rem 1rem;
      border-radius: 2px;
      display: none;
      line-height: 1.4;
    }

    .btn-login {
      font-family: 'Jost', sans-serif;
      font-size: 0.75rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.85rem 1rem;
      background: var(--niebla);
      color: white;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
      border-radius: 3px;
      width: 100%;
      margin-top: 0.5rem;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-login:hover {
      background: var(--texto);
    }

    .btn-login:disabled {
      background: var(--niebla-claro);
      cursor: not-allowed;
    }

    .login-footer {
      padding: 0 2rem 2.2rem;
      text-align: center;
    }

    .login-footer a {
      font-size: 0.7rem;
      color: var(--texto-suave);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.2s ease;
    }

    .login-footer a:hover {
      color: var(--niebla);
    }

    /* Loader icon */
    .spinner {
      width: 14px;
      height: 14px;
      border: 2px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      border-top-color: #white;
      animation: spin 0.8s ease infinite;
      display: none;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .workspace-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }

    .workspace-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.9rem 1.1rem;
      background: var(--blanco);
      border: 1px solid var(--borde);
      border-radius: 4px;
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: left;
      width: 100%;
    }

    .workspace-item:hover {
      border-color: var(--niebla);
      background: var(--niebla-palido);
      transform: translateY(-1px);
    }

    .workspace-name {
      font-size: 0.82rem;
      font-weight: 500;
      color: var(--texto);
    }

    .workspace-role {
      font-size: 0.58rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--texto-muted);
    }
  </style>
</head>
<body>

  <div class="login-container">
    <div class="login-header">
      <h1>Atmósfera</h1>
      <p>Gestión de servicios</p>
    </div>
    
    <form id="loginForm" novalidate>
      <div class="login-body">
        <div id="errorAlert" class="alert-error">
          Las credenciales ingresadas son incorrectas.
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Correo electrónico</label>
          <input class="form-input" type="email" id="email" required placeholder="ejemplo@atmosfera.com">
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Contraseña</label>
          <input class="form-input" type="password" id="password" required placeholder="••••••••">
        </div>

        <button class="btn-login" type="submit" id="submitBtn">
          <span class="spinner" id="btnSpinner"></span>
          <span id="btnText">Ingresar</span>
        </button>
      </div>
    </form>

    <div id="workspaceSection" style="display: none;" class="login-body">
      <div class="form-group">
        <label class="form-label">Selecciona tu espacio de trabajo:</label>
        <div id="workspaceList" class="workspace-list">
          <!-- Se cargan dinámicamente -->
        </div>
      </div>
      
      <button class="btn-login" style="margin-top: 0.5rem; background: var(--texto-suave);" id="backToLoginBtn" type="button">
        Volver
      </button>
    </div>

    <div class="login-footer">
      <a href="https://atmosferastudio.cl">← Volver al sitio principal</a>
    </div>
  </div>

  <script>
    import { apiFetch } from "../services/api";

    interface MembershipOption {
      id: string;
      businessName?: string;
      role: string;
    }

    interface SessionUser {
      role: string;
      businessSlug?: string;
    }

    interface AuthResponse {
      status: string;
      message?: string;
      payload?: SessionUser;
      user?: SessionUser;
      memberships?: MembershipOption[];
    }

    const loginForm = document.getElementById("loginForm") as HTMLFormElement;
    const emailInput = document.getElementById("email") as HTMLInputElement;
    const passwordInput = document.getElementById("password") as HTMLInputElement;
    const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;
    const btnSpinner = document.getElementById("btnSpinner") as HTMLElement;
    const btnText = document.getElementById("btnText") as HTMLElement;
    const errorAlert = document.getElementById("errorAlert") as HTMLElement;
    
    const workspaceSection = document.getElementById("workspaceSection") as HTMLElement;
    const workspaceList = document.getElementById("workspaceList") as HTMLElement;
    const backToLoginBtn = document.getElementById("backToLoginBtn") as HTMLButtonElement;

    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      const email = emailInput.value.trim();
      const password = passwordInput.value;

      if (!email || !password) {
        showError("Por favor, rellene todos los campos.");
        return;
      }

      // Limpiar errores previos y mostrar spinner
      hideError();
      setLoading(true);

      try {
        const response = await apiFetch<AuthResponse>("/login", {
          method: "POST",
          body: JSON.stringify({ email, password })
        });

        if (response && (response.status === "success" || response.status === "succes")) {
          const user = response.payload || response.user;
          handleSuccessfulLogin(user);
        } else if (response && response.status === "needs_selection") {
          showWorkspaceSelector(response.memberships ?? []);
        } else {
          showError(response?.message || "Ocurrió un error inesperado al intentar iniciar sesión.");
          setLoading(false);
        }
      } catch (err) {
        showError("El correo o la contraseña son incorrectos.");
        setLoading(false);
      }
    });

    backToLoginBtn.addEventListener("click", () => {
      workspaceSection.style.display = "none";
      loginForm.style.display = "block";
      hideError();
    });

    function showWorkspaceSelector(memberships: MembershipOption[]) {
      setLoading(false);
      loginForm.style.display = "none";
      workspaceSection.style.display = "flex";
      workspaceList.innerHTML = "";

      memberships.forEach(m => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "workspace-item";
        
        const roleLabel = m.role === "admin" 
          ? "Administrador" 
          : m.role === "superadmin" 
            ? "Superadmin" 
            : "Especialista";

        btn.innerHTML = `
          <span class="workspace-name">${m.businessName || 'Negocio'}</span>
          <span class="workspace-role">${roleLabel}</span>
        `;
        
        btn.addEventListener("click", async () => {
          setLoading(true);
          try {
            const selectRes = await apiFetch<AuthResponse>("/select-membership", {
              method: "POST",
              body: JSON.stringify({ membershipId: m.id })
            });
            if (selectRes && selectRes.status === "success") {
              const user = selectRes.payload || selectRes.user;
              handleSuccessfulLogin(user);
            } else {
              showError(selectRes?.message || "Error al seleccionar el espacio de trabajo.");
              setLoading(false);
            }
          } catch (err) {
            showError("Error de conexión al seleccionar el espacio.");
            setLoading(false);
          }
        });
        workspaceList.appendChild(btn);
      });
    }

    function handleSuccessfulLogin(user: SessionUser | undefined) {
      if (!user) {
        showError("No fue posible recuperar los datos de la sesión.");
        setLoading(false);
        return;
      }

      if (user.role === "admin" || user.role === "worker" || user.role === "superadmin") {
        const slug = user.businessSlug;
        if (slug) {
          window.location.href = `/admin?slug=${slug}`;
        } else {
          window.location.href = "/admin";
        }
      } else {
        showError("No tienes permisos de acceso para esta plataforma.");
        setLoading(false);
      }
    }

    function showError(msg: string) {
      errorAlert.textContent = msg;
      errorAlert.style.display = "block";
    }

    function hideError() {
      errorAlert.style.display = "none";
    }

    function setLoading(isLoading: boolean) {
      if (isLoading) {
        submitBtn.disabled = true;
        btnSpinner.style.display = "inline-block";
        btnText.textContent = "Cargando...";
      } else {
        submitBtn.disabled = false;
        btnSpinner.style.display = "none";
        btnText.textContent = "Ingresar";
      }
    }
  </script>
</body>
</html>
