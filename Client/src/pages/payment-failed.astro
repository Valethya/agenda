---
// Client-side code to extract query params and display payment failures
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pago Fallido - LuxurBooking</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --bg-dark: #090d16;
      --bg-card: rgba(18, 24, 38, 0.65);
      --border-color: rgba(255, 255, 255, 0.08);
      --text-main: #f3f4f6;
      --text-muted: #9ca3af;
      --radius-lg: 16px;
      --radius-md: 12px;
      --transition: all 0.3s ease;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: absolute;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(239, 68, 68, 0.12) 0%, rgba(0,0,0,0) 70%);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: -1;
      pointer-events: none;
    }

    .card {
      background: var(--bg-card);
      backdrop-filter: blur(12px);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-lg);
      padding: 3rem 2rem;
      max-width: 450px;
      width: 100%;
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      animation: scaleUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @keyframes scaleUp {
      from { transform: scale(0.9); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .error-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: rgba(239, 68, 68, 0.1);
      border: 2px solid #ef4444;
      color: #ef4444;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 0 20px rgba(239, 68, 68, 0.2);
    }

    .error-icon svg {
      width: 44px;
      height: 44px;
    }

    h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    p {
      color: var(--text-muted);
      line-height: 1.6;
      font-size: 0.95rem;
    }

    .details-box {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border-color);
      border-radius: var(--radius-md);
      padding: 1.25rem;
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      font-size: 0.9rem;
      text-align: left;
    }

    .detail-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .detail-label {
      color: var(--text-muted);
    }

    .detail-val {
      font-weight: 600;
    }

    .btn-retry {
      width: 100%;
      background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
      border: none;
      color: white;
      padding: 1rem;
      font-size: 1rem;
      font-weight: 700;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      transition: var(--transition);
      box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
      display: inline-block;
    }

    .btn-retry:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(239, 68, 68, 0.45);
    }

    .btn-secondary {
      width: 100%;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border-color);
      color: var(--text-main);
      padding: 0.85rem;
      font-size: 0.95rem;
      font-weight: 600;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      transition: var(--transition);
      display: inline-block;
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.1);
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="error-icon">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </div>
    
    <h1>No se pudo procesar el pago</h1>
    <p id="errorDescription">La transacción fue rechazada o cancelada. Tu reserva no se ha completado. Por favor, intenta pagar nuevamente.</p>
    
    <div class="details-box">
      <div class="detail-row">
        <span class="detail-label">Causa del error</span>
        <span class="detail-val" id="errorReason" style="color:#f87171;">Rechazo bancario</span>
      </div>
      <div class="detail-row" id="appRow" style="display:none;">
        <span class="detail-label">Nº de Cita</span>
        <span class="detail-val" id="appId">-</span>
      </div>
    </div>
    
    <a href="/agenda" class="btn-retry" id="btnRetry">Intentar de Nuevo</a>
    <a href="/agenda" class="btn-secondary" id="btnBack">Volver a la Agenda</a>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const reason = params.get("reason") || "";
    const message = params.get("message") || "";
    const appointmentId = params.get("appointmentId") || "";
    const slug = params.get("slug");

    const descEl = document.getElementById("errorDescription") as HTMLElement;
    const reasonEl = document.getElementById("errorReason") as HTMLElement;
    const appRow = document.getElementById("appRow") as HTMLElement;
    const appIdEl = document.getElementById("appId") as HTMLElement;
    const retryLink = document.getElementById("btnRetry") as HTMLAnchorElement;
    const backLink = document.getElementById("btnBack") as HTMLAnchorElement;

    if (appointmentId) {
      appRow.style.display = "flex";
      appIdEl.innerText = appointmentId.substring(18).toUpperCase();
    }

    // Actualizar enlaces de retorno con el slug
    const agendaUrl = slug ? `/agenda?slug=${encodeURIComponent(slug)}` : "/agenda";
    retryLink.href = agendaUrl;
    backLink.href = agendaUrl;

    switch(reason) {
      case "cancelled_by_user":
        reasonEl.innerText = "Cancelado por el usuario";
        descEl.innerText = "Decidiste cancelar el proceso de pago en la pasarela de Webpay. Puedes volver a intentarlo.";
        break;
      case "rejected":
        reasonEl.innerText = "Transacción rechazada";
        descEl.innerText = "El banco o emisor de tu tarjeta ha rechazado la transacción. Por favor, verifica tu cupo o intenta con otro medio de pago.";
        break;
      case "missing_token":
        reasonEl.innerText = "Token de transacción inválido";
        descEl.innerText = "No se detectó un token de Webpay válido. La transacción no se pudo validar.";
        break;
      case "server_error":
        reasonEl.innerText = "Error técnico del servidor";
        descEl.innerText = message ? `Detalle: ${decodeURIComponent(message)}` : "Ocurrió un error al procesar el pago en nuestro servidor.";
        break;
      default:
        reasonEl.innerText = "Error desconocido";
        descEl.innerText = "No pudimos completar la validación de tu pago. Por favor, ponte en contacto con nosotros.";
        break;
    }
  </script>
</body>
</html>
